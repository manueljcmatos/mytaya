---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLangFromUrl } from '../i18n/utils';
import { getAbsoluteLocaleUrl } from 'astro:i18n';
import { pwaInfo } from 'virtual:pwa-info';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  schema?: Record<string, unknown>;
  noindex?: boolean;
  lang?: string;
}

const currentLang = Astro.props.lang || getLangFromUrl(Astro.url);
const htmlLang = currentLang === 'tl' ? 'fil-PH' : 'en-PH';

const {
  title,
  description = currentLang === 'tl'
    ? 'Mga tamang hula sa basketball, football, at boxing para sa Filipino'
    : 'Expert sports predictions for basketball, football, and boxing for the Filipino bettor',
  ogImage = '/og-default.png',
  ogType = 'website',
  schema,
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;

// Build hreflang URLs - strip locale prefix, reconstruct for each locale
const pathWithoutLocale = Astro.url.pathname.replace(/^\/(tl|en)\//, '/');
const tlUrl = getAbsoluteLocaleUrl('tl', pathWithoutLocale);
const enUrl = getAbsoluteLocaleUrl('en', pathWithoutLocale);

const ogLocale = currentLang === 'tl' ? 'fil_PH' : 'en_PH';
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Tag Manager -->
    <script is:inline>
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-52XTJZ7M');
    </script>
    <!-- End Google Tag Manager -->

    <!-- FOUC prevention: apply theme before any rendering -->
    <script is:inline>
      (function(){var t=localStorage.getItem('theme');if(t==='light')document.documentElement.classList.add('light');})();
    </script>

    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Hreflang tags for bilingual SEO -->
    <link rel="alternate" hreflang="fil" href={tlUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="x-default" href={tlUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="MyTaya" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <!-- Google Fonts: Bebas Neue (display) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />

    <!-- Theme color and PWA -->
    <meta name="theme-color" content="#0F766E" />
    <link rel="apple-touch-icon" href="/icon-192.png" />

    <!-- JSON-LD structured data -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- Page-specific head content -->
    <slot name="head" />

    <title>{title}</title>

    <!-- PWA manifest -->
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-52XTJZ7M"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />

    <!-- PWA service worker registration -->
    <script>
      import { registerSW } from 'virtual:pwa-register';
      registerSW({ immediate: true });
    </script>
  </body>
</html>
