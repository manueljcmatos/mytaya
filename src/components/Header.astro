---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { NAV_ITEMS, SOCIAL_LINKS } from '../lib/constants';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const navLinks = NAV_ITEMS.map((item) => ({
  href: item.path[lang],
  label: t(item.key),
}));

const telegramText = t('cta.telegram');
---

<header class="sticky top-0 z-50 glass" style={`background-color: var(--t-header-bg); border-bottom: 1px solid var(--t-header-border);`}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[4.5rem]">
      <!-- Logo / Wordmark -->
      <a href={`/${lang}/`} class="flex items-center gap-1.5 shrink-0">
        <span style="font-family: var(--font-display);" class="text-2xl tracking-wide">
          <span style="color: var(--color-brand-primary);">MY</span><span style="color: var(--t-text);">TAYA</span>
        </span>
      </a>

      <!-- Desktop Nav (centered) -->
      <nav class="hidden lg:flex items-center gap-7">
        {navLinks.map((link) => (
          <a href={link.href} class="nav-link">{link.label}</a>
        ))}
      </nav>

      <!-- Desktop: Language Switcher + Theme Toggle + Telegram CTA -->
      <div class="hidden lg:flex items-center gap-3">
        <LanguageSwitcher />
        <ThemeToggle />
        <a
          href={SOCIAL_LINKS.telegram}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-medium transition-colors ml-1"
          style="color: var(--t-brand);"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          <span>{telegramText}</span>
        </a>
      </div>

      <!-- Mobile: Theme Toggle + Language Switcher + Hamburger -->
      <div class="flex lg:hidden items-center gap-2">
        <ThemeToggle />
        <LanguageSwitcher />
        <button
          id="mobile-menu-btn"
          class="p-2 rounded-lg transition-colors"
          style="color: var(--t-text-sec);"
          aria-label="Menu"
          aria-expanded="false"
        >
          <svg id="menu-icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="menu-icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden" style={`background-color: var(--t-header-bg); border-top: 1px solid var(--t-header-border);`}>
    <div class="px-4 py-5 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-sm font-medium py-2.5 px-3 rounded-lg transition-colors"
          style="color: var(--t-text-sec);"
        >
          {link.label}
        </a>
      ))}
      <div class="pt-3 mt-3" style="border-top: 1px solid var(--t-header-border);">
        <a
          href={SOCIAL_LINKS.telegram}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm font-medium py-2.5 px-3 rounded-lg"
          style="color: var(--t-brand);"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          {telegramText}
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('menu-icon-open');
    const iconClose = document.getElementById('menu-icon-close');

    btn?.addEventListener('click', () => {
      const isNowHidden = menu?.classList.toggle('hidden');
      iconOpen?.classList.toggle('hidden', !isNowHidden);
      iconClose?.classList.toggle('hidden', isNowHidden);
      btn.setAttribute('aria-expanded', isNowHidden ? 'false' : 'true');
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
