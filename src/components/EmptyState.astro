---
interface Props {
  message: string;
  icon?: string;
}

const { message, icon } = Astro.props;
---

<div class="empty-state">
  <div class="empty-state-icon" aria-hidden="true">
    {icon ? (
      <span class="text-3xl">{icon}</span>
    ) : (
      <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="empty-svg">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="16" y1="2" x2="16" y2="6"></line>
        <line x1="8" y1="2" x2="8" y2="6"></line>
        <line x1="3" y1="10" x2="21" y2="10"></line>
      </svg>
    )}
  </div>
  <p class="empty-state-message">{message}</p>
  <slot />
</div>

<style>
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    text-align: center;
    border: 1px dashed var(--t-border);
    border-radius: 0.75rem;
    background-color: color-mix(in srgb, var(--t-bg-card) 50%, transparent);
  }
  .empty-state-icon {
    margin-bottom: 1rem;
    color: var(--t-text-sec);
    opacity: 0.5;
  }
  .empty-svg {
    color: var(--t-text-sec);
  }
  .empty-state-message {
    font-size: 0.9375rem;
    color: var(--t-text-sec);
    font-family: var(--font-body);
    max-width: 20rem;
    line-height: 1.5;
  }
</style>
