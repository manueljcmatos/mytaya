---
import type { Operator } from '../../data/operators';

interface Props {
  operator: Operator;
  lang: 'tl' | 'en';
}

const { operator, lang } = Astro.props;

const reviewPath = lang === 'tl'
  ? `/tl/mga-operator/${operator.slug}/`
  : `/en/operators/${operator.slug}/`;

const ctaText = lang === 'tl' ? 'Mag-sign Up' : 'Sign Up Now';
const reviewText = lang === 'tl' ? 'Basahin ang Review' : 'Read Review';

// Generate star display
const fullStars = Math.floor(operator.rating);
const hasHalfStar = operator.rating % 1 >= 0.5;
---

<div class="operator-card card card-hover">
  <div class="card-badge">21+</div>

  <div class="card-header">
    <div class="card-logo" aria-label={operator.name}>
      <span class="logo-initials">{operator.name.substring(0, 2).toUpperCase()}</span>
    </div>
    <div class="card-title-area">
      <h3 class="card-name">{operator.name}</h3>
      <div class="card-rating" aria-label={`Rating: ${operator.rating} out of 5`}>
        {Array.from({ length: 5 }).map((_, i) => (
          <span class={`star ${i < fullStars ? 'star-filled' : i === fullStars && hasHalfStar ? 'star-half' : 'star-empty'}`}>
            {i < fullStars ? '\u2605' : i === fullStars && hasHalfStar ? '\u2605' : '\u2606'}
          </span>
        ))}
        <span class="rating-number">{operator.rating}</span>
      </div>
    </div>
  </div>

  <div class="card-bonus">
    <span class="bonus-label">{lang === 'tl' ? 'Welcome Bonus' : 'Welcome Bonus'}</span>
    <span class="bonus-value">{operator.welcomeBonus[lang]}</span>
  </div>

  <p class="card-description">{operator.description[lang]}</p>

  <ul class="card-features">
    {operator.features.slice(0, 3).map((feature) => (
      <li class="feature-item">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
        {feature}
      </li>
    ))}
  </ul>

  <div class="card-actions">
    <a
      href={operator.affiliateUrl}
      rel="sponsored nofollow noopener"
      target="_blank"
      class="btn-primary btn-sm card-cta"
    >
      {ctaText}
    </a>
    <a href={reviewPath} class="link-arrow card-review-link">
      {reviewText}
    </a>
  </div>
</div>

<style>
  .operator-card {
    position: relative;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .card-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background-color: color-mix(in srgb, var(--color-loss) 15%, transparent);
    color: var(--color-loss);
    font-size: 0.6875rem;
    font-weight: 700;
    font-family: var(--font-body);
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    letter-spacing: 0.025em;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.875rem;
  }

  .card-logo {
    width: 3rem;
    height: 3rem;
    border-radius: 0.625rem;
    background: linear-gradient(135deg, var(--color-brand-primary), var(--color-brand-light));
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .logo-initials {
    color: #FFFFFF;
    font-family: var(--font-display);
    font-size: 1.125rem;
    letter-spacing: 0.05em;
  }

  .card-title-area {
    flex: 1;
    min-width: 0;
  }

  .card-name {
    font-family: var(--font-display);
    font-size: 1.375rem;
    color: var(--t-text);
    margin: 0;
    line-height: 1.2;
  }

  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    margin-top: 0.125rem;
  }

  .star {
    font-size: 0.875rem;
    line-height: 1;
  }

  .star-filled {
    color: var(--color-push);
  }

  .star-half {
    color: var(--color-push);
    opacity: 0.6;
  }

  .star-empty {
    color: var(--t-text-sec);
    opacity: 0.3;
  }

  .rating-number {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--t-text-sec);
    margin-left: 0.25rem;
  }

  .card-bonus {
    background-color: color-mix(in srgb, var(--color-brand-primary) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-brand-primary) 15%, transparent);
    border-radius: 0.5rem;
    padding: 0.625rem 0.875rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .bonus-label {
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--t-brand);
  }

  .bonus-value {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--t-text);
    font-family: var(--font-body);
  }

  .card-description {
    font-size: 0.8125rem;
    color: var(--t-text-sec);
    line-height: 1.6;
    margin: 0;
  }

  .card-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--t-text-body);
    font-family: var(--font-body);
  }

  .feature-item svg {
    color: var(--t-brand);
    flex-shrink: 0;
  }

  .card-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-cta {
    flex-shrink: 0;
  }

  .card-review-link {
    font-size: 0.8125rem;
  }
</style>
