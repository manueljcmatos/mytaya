---
interface Props {
  lang: 'tl' | 'en';
}

const { lang } = Astro.props;

const text = {
  tl: {
    badge: '21+',
    message: 'Para sa 21 taong gulang pataas lamang. Magsugal nang responsable.',
  },
  en: {
    badge: '21+',
    message: 'For 21 years old and above only. Gamble responsibly.',
  },
};

const t = text[lang];
---

<div class="age-notice">
  <span class="age-notice__badge">{t.badge}</span>
  <span class="age-notice__message">{t.message}</span>
</div>

<style>
  .age-notice {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 1rem;
    background-color: var(--t-bg-card);
    border: 1px solid var(--t-border);
    border-radius: 0.5rem;
    font-family: var(--font-body);
  }

  .age-notice__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 700;
    color: #fff;
    background-color: var(--color-loss);
    flex-shrink: 0;
  }

  .age-notice__message {
    font-size: 0.8125rem;
    color: var(--t-text-sec);
    line-height: 1.4;
  }
</style>
