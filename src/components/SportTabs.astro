---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

interface Props {
  lang?: string;
  activeSport?: string;
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const t = useTranslations(lang as 'tl' | 'en');
const activeSport = Astro.props.activeSport || '';

const predictionsBase = lang === 'tl' ? '/tl/hula/' : '/en/predictions/';

const boxingBase = lang === 'tl' ? '/tl/boksing/' : '/en/boxing/';

const sportConfig = [
  { id: 'basketball', icon: '\u{1F3C0}', label: t('sport.basketball'), href: `${predictionsBase}?sport=basketball` },
  { id: 'football', icon: '\u26BD', label: t('sport.football'), href: `${predictionsBase}?sport=football` },
  { id: 'boxing', icon: '\u{1F94A}', label: t('sport.boxing'), href: boxingBase },
];
---

<nav class="sport-tabs" aria-label="Sport categories">
  <div class="tabs-container">
    {sportConfig.map(sport => (
      <a
        href={sport.href}
        class:list={[
          'sport-tab',
          { 'sport-tab--active': activeSport === sport.id }
        ]}
        aria-current={activeSport === sport.id ? 'page' : undefined}
      >
        <span class="sport-tab-icon" aria-hidden="true">{sport.icon}</span>
        <span class="sport-tab-label">{sport.label}</span>
      </a>
    ))}
  </div>
</nav>

<style>
  .sport-tabs {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .sport-tabs::-webkit-scrollbar {
    display: none;
  }
  .tabs-container {
    display: flex;
    gap: 0.5rem;
    padding: 0.25rem;
    background-color: color-mix(in srgb, var(--t-bg-card) 80%, transparent);
    border: 1px solid var(--t-border);
    border-radius: 0.75rem;
    width: fit-content;
  }
  .sport-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    border-radius: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--t-text-sec);
    text-decoration: none;
    white-space: nowrap;
    transition: all 0.2s ease;
  }
  .sport-tab:hover {
    color: var(--t-text);
    background-color: var(--t-bg-hover);
  }
  .sport-tab--active {
    color: #fff;
    background-color: var(--color-brand-primary);
  }
  .sport-tab--active:hover {
    color: #fff;
    background-color: var(--color-brand-light);
  }
  .sport-tab-icon {
    font-size: 1.125rem;
    line-height: 1;
  }
  .sport-tab-label {
    line-height: 1;
  }
</style>
