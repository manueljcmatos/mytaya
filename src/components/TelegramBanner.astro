---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { SOCIAL_LINKS } from '../lib/constants';

interface Props {
  lang?: string;
}

const lang = Astro.props.lang || getLangFromUrl(Astro.url);
const t = useTranslations(lang as 'tl' | 'en');

const headline = lang === 'tl'
  ? 'Sumali sa MyTaya Telegram'
  : 'Join the MyTaya Telegram';
const description = lang === 'tl'
  ? 'Makakuha ng mga libreng hula, real-time alerts, at exclusive tips mula sa aming komunidad.'
  : 'Get free predictions, real-time alerts, and exclusive tips from our community.';
---

<section class="telegram-banner">
  <div class="telegram-banner-inner">
    <!-- Telegram icon -->
    <div class="telegram-icon-wrap">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" class="telegram-icon">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
    </div>

    <!-- Content -->
    <div class="telegram-content">
      <h3 class="telegram-headline">{headline}</h3>
      <p class="telegram-description">{description}</p>
    </div>

    <!-- CTA -->
    <a href={SOCIAL_LINKS.telegram} target="_blank" rel="noopener noreferrer" class="btn-primary telegram-cta">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      {t('cta.telegram')}
    </a>
  </div>
</section>

<style>
  .telegram-banner {
    padding: 0 1rem;
  }
  .telegram-banner-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem 1.5rem;
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-brand-primary) 20%, transparent);
    background: linear-gradient(135deg,
      color-mix(in srgb, var(--color-brand-primary) 8%, var(--t-bg-card)),
      var(--t-bg-card)
    );
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .telegram-banner-inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 0%, color-mix(in srgb, var(--color-brand-primary) 10%, transparent) 0%, transparent 60%);
    pointer-events: none;
  }
  .telegram-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    background-color: color-mix(in srgb, var(--color-brand-primary) 15%, transparent);
    color: var(--t-brand);
    position: relative;
  }
  .telegram-content {
    position: relative;
  }
  .telegram-headline {
    font-size: 1.5rem;
    letter-spacing: 0.05em;
    color: var(--t-text);
    margin-bottom: 0.375rem;
  }
  .telegram-description {
    font-size: 0.9375rem;
    color: var(--t-text-sec);
    font-family: var(--font-body);
    line-height: 1.6;
    max-width: 28rem;
    margin: 0 auto;
  }
  .telegram-cta {
    position: relative;
    padding: 0.75rem 2rem;
  }

  @media (min-width: 640px) {
    .telegram-banner-inner {
      flex-direction: row;
      text-align: left;
      padding: 2rem 2.5rem;
      gap: 1.5rem;
    }
    .telegram-description {
      margin: 0;
    }
    .telegram-cta {
      margin-left: auto;
      white-space: nowrap;
    }
  }
</style>
