---
import Layout from '../../../layouts/Layout.astro';
import StatsDashboard from '../../../components/statistics/StatsDashboard';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { SITE } from '../../../lib/constants';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<Layout title={`${t('stats.title')} - MyTaya`} lang={lang}>
  <Fragment slot="head">
    <link rel="alternate" hreflang="fil" href={`${SITE.url}/tl/estadistika/`} />
    <link rel="alternate" hreflang="en" href={`${SITE.url}/en/statistics/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.url}/tl/estadistika/`} />
    <meta property="og:url" content={`${SITE.url}/en/statistics/`} />
  </Fragment>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <h1 class="text-4xl sm:text-5xl tracking-wide mb-6 text-gradient-brand">{t('stats.title')}</h1>

    <StatsDashboard client:load lang="en" />
  </div>
</Layout>
