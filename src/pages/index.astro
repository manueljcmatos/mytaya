---
// Root page: instant redirect to default locale
// Language detection happens client-side for static builds
---

<html>
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/tl/" />
    <link rel="canonical" href="https://mytaya.com/tl/" />
    <script is:inline>
      var lang = (navigator.language || '').toLowerCase();
      var target = lang.startsWith('en') ? '/en/' : '/tl/';
      window.location.replace(target);
    </script>
  </head>
  <body></body>
</html>
