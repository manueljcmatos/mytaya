---
import Layout from '../../../layouts/Layout.astro';
import { getAllBlogSlugs, getBlogPostBySlug } from '../../../lib/posts';
import { buildBlogPostingSchema, buildBreadcrumbSchema } from '../../../lib/seo';
import { SITE } from '../../../lib/constants';

export async function getStaticPaths() {
  const slugs = await getAllBlogSlugs();
  return slugs
    .filter((s) => s.slug_tl)
    .map((s) => ({ params: { slug: s.slug_tl } }));
}

const { slug } = Astro.params;

let title = 'Blog - MyTaya';
let description = 'Basahin ang aming ekspertong pagsusuri sa hula sa sports.';
let schema: Record<string, unknown> | undefined;
let breadcrumbSchema: Record<string, unknown> | undefined;
let post: any = null;
let predictionSlug: string | null = null;
let slugEn: string | null = null;

if (slug) {
  post = await getBlogPostBySlug(slug, 'tl');

  if (post) {
    title = `${post.title_tl} - MyTaya`;
    if (post.excerpt_tl) {
      description = post.excerpt_tl.substring(0, 160);
    }
    slugEn = post.slug_en;

    if (post.prediction?.slug) {
      predictionSlug = post.prediction.slug;
    }

    schema = buildBlogPostingSchema({
      title: post.title_tl,
      description: post.excerpt_tl || '',
      datePublished: post.published_at,
      url: `${SITE.url}/tl/blog/${post.slug_tl}/`,
      lang: 'tl',
    });

    breadcrumbSchema = buildBreadcrumbSchema([
      { name: 'Home', url: `${SITE.url}/tl/` },
      { name: 'Blog', url: `${SITE.url}/tl/blog/` },
      { name: post.title_tl, url: `${SITE.url}/tl/blog/${post.slug_tl}/` },
    ]);
  }
}

const enAlternate = slugEn ? `/en/blog/${slugEn}/` : '/en/blog/';

// Parse content sections for result callout rendering
function parseContent(content: string | null): { body: string; resultSection: string | null; resultType: string | null } {
  if (!content) return { body: '', resultSection: null, resultType: null };

  const resultMatch = content.match(/## Resulta?\s*\n([\s\S]*?)(?=\n## |$)/i);
  if (!resultMatch) return { body: content, resultSection: null, resultType: null };

  const resultText = resultMatch[1].trim();
  const body = content.replace(/## Resulta?\s*\n[\s\S]*?(?=\n## |$)/i, '').trim();

  let resultType: string | null = null;
  const lowerResult = resultText.toLowerCase();
  if (lowerResult.includes('panalo') || lowerResult.includes('win')) resultType = 'win';
  else if (lowerResult.includes('talo') || lowerResult.includes('loss') || lowerResult.includes('lost')) resultType = 'loss';
  else if (lowerResult.includes('push')) resultType = 'push';

  return { body, resultSection: resultText, resultType };
}

const parsed = post ? parseContent(post.content_tl) : { body: '', resultSection: null, resultType: null };

const resultStyles: Record<string, { bg: string; border: string }> = {
  win: { bg: 'bg-emerald-500/10', border: 'border-emerald-500' },
  loss: { bg: 'bg-red-500/10', border: 'border-red-500' },
  push: { bg: 'bg-amber-500/10', border: 'border-amber-500' },
};

function formatDate(isoDate: string): string {
  return new Intl.DateTimeFormat('fil-PH', {
    timeZone: 'Asia/Manila',
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(isoDate));
}

function renderMarkdown(text: string): string {
  return text
    .split('\n\n')
    .map((block) => {
      const trimmed = block.trim();
      if (!trimmed) return '';
      if (trimmed.startsWith('### ')) return `<h3 class="text-xl font-bold mt-6 mb-3" style="color: var(--t-text, #f9fafb); font-family: var(--font-display, 'Bebas Neue', sans-serif);">${trimmed.slice(4)}</h3>`;
      if (trimmed.startsWith('## ')) return `<h2 class="text-2xl font-bold mt-8 mb-4" style="color: var(--t-text, #f9fafb); font-family: var(--font-display, 'Bebas Neue', sans-serif);">${trimmed.slice(3)}</h2>`;
      return `<p class="mb-4 leading-relaxed" style="color: var(--t-text-sec, #d1d5db);">${trimmed}</p>`;
    })
    .join('\n');
}
---

<Layout title={title} description={description} schema={schema} lang="tl">
  <Fragment slot="head">
    <link rel="alternate" hreflang="en" href={`${SITE.url}${enAlternate}`} />
    <link rel="alternate" hreflang="fil" href={`${SITE.url}/tl/blog/${slug}/`} />
    <link rel="alternate" hreflang="x-default" href={`${SITE.url}/tl/blog/${slug}/`} />
    <meta property="og:url" content={`${SITE.url}/tl/blog/${slug}/`} />
    {breadcrumbSchema && (
      <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
  </Fragment>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    {post ? (
      <>
        {/* Breadcrumb */}
        <nav class="flex items-center gap-2 text-xs mb-6" style="color: var(--t-text-sec, #9ca3af);">
          <a href="/tl/" class="hover:underline">Home</a>
          <span aria-hidden="true">&rsaquo;</span>
          <a href="/tl/blog/" class="hover:underline">Blog</a>
          <span aria-hidden="true">&rsaquo;</span>
          <span style="color: var(--t-text, #f9fafb);">{post.title_tl}</span>
        </nav>

        {/* Article header */}
        <article>
          <header class="mb-8">
            <div class="flex items-center gap-2 mb-3">
              <span
                class="text-xs font-bold uppercase tracking-wider px-2 py-0.5 rounded-full"
                style={`background-color: ${post.sport === 'basketball' ? 'rgba(249, 115, 22, 0.15)' : 'rgba(15, 118, 110, 0.15)'}; color: ${post.sport === 'basketball' ? '#f97316' : 'var(--brand-primary, #0F766E)'};`}
              >
                {post.sport}
              </span>
            </div>
            <h1
              class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-4 leading-tight"
              style="color: var(--t-text, #f9fafb); font-family: var(--font-display, 'Bebas Neue', sans-serif);"
            >
              {post.title_tl}
            </h1>
            <div class="flex items-center gap-3 text-sm" style="color: var(--t-text-sec, #9ca3af);">
              <time datetime={post.published_at}>{formatDate(post.published_at)}</time>
              {post.read_time_minutes && (
                <>
                  <span aria-hidden="true">&middot;</span>
                  <span>{post.read_time_minutes} min basahin</span>
                </>
              )}
            </div>
          </header>

          {/* Article body */}
          <div class="prose-custom" set:html={renderMarkdown(parsed.body)} />

          {/* Result callout */}
          {parsed.resultSection && parsed.resultType && (
            <div class={`mt-8 p-6 rounded-xl border-l-4 ${resultStyles[parsed.resultType]?.bg || ''} ${resultStyles[parsed.resultType]?.border || ''}`}>
              <h2
                class="text-xl font-bold mb-3"
                style="color: var(--t-text, #f9fafb); font-family: var(--font-display, 'Bebas Neue', sans-serif);"
              >
                Resulta
              </h2>
              <div set:html={renderMarkdown(parsed.resultSection)} />
            </div>
          )}

          {/* Cross-link to prediction */}
          {predictionSlug && (
            <div
              class="mt-8 p-4 rounded-xl flex items-center justify-between"
              style="background-color: var(--t-surface, #1f2937); border: 1px solid var(--t-border, #374151);"
            >
              <span style="color: var(--t-text-sec, #9ca3af);">Tingnan ang aming hula para sa larong ito</span>
              <a
                href={`/tl/hula/${predictionSlug}/`}
                class="px-4 py-2 rounded-lg text-sm font-medium"
                style="background-color: var(--brand-primary, #0F766E); color: #ffffff;"
              >
                Tingnan ang Hula
              </a>
            </div>
          )}
        </article>
      </>
    ) : (
      <div class="text-center py-20">
        <p style="color: var(--t-text-sec, #9ca3af);">Hindi natagpuan ang artikulo.</p>
        <a href="/tl/blog/" class="mt-4 inline-block underline" style="color: var(--brand-primary, #0F766E);">
          Bumalik sa Blog
        </a>
      </div>
    )}
  </div>
</Layout>
